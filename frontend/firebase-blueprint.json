{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User account information for SafeScan AI access.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Ingestion": {
      "title": "Payload Ingestion",
      "description": "Information about an APK or payload ingested for analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "fileSize": { "type": "integer" },
        "sector": { "type": "string" },
        "status": { "type": "string", "enum": ["SECURE", "WARNING", "DANGER"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" }
      },
      "required": ["userId", "fileName", "status", "timestamp"]
    },
    "Verdict": {
      "title": "Neural Verdict",
      "description": "Live detections from the neural network.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "alert"] },
        "userId": { "type": "string" }
      },
      "required": ["timestamp", "title", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles."
    },
    "/ingestions/{ingestionId}": {
      "schema": "Ingestion",
      "description": "Record of ingested binaries."
    },
    "/verdicts/{verdictId}": {
      "schema": "Verdict",
      "description": "Live security verdicts."
    }
  }
}
